*.o
*.d

# Xcode user-specific files (each dev gets their own)
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Xcode scratch files
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Xcode schemes — keep shared schemes, ignore personal ones
*.xcodeproj/xcshareddata/xcdebugger/
!*.xcodeproj/xcshareddata/xcschemes/

# Playground output
playground.xcworkspace

